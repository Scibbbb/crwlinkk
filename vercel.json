{
  "version": 2,
  "builds": [
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "api/*.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/app", "dest": "/Crwlink.html" },
    { "src": "/app/profile", "dest": "/Crwlink.html" },
    { "src": "/", "dest": "/crwlink_landing.html" }
  ]
}
